{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Builder-Assistant-Repo/schemas/checkpoint.schema.json",
  "title": "EV4 Builder Checkpoint",
  "description": "Backward-compatible checkpoint schema. Supports legacy ev4-builder-checkpoint@0.1.0 and assertion/evidence based ev4-builder-checkpoint@0.2.0.",
  "$defs": {
    "workflow_mode": {
      "enum": ["START_INTAKE_MODE", "APPROVED_HANDOFF_MODE", "FRESH_IMAGE_MODE_LIMITED"]
    },
    "runtime_state": {
      "enum": ["INTAKE_WAITING", "INTAKE_VALIDATING", "BUILD_ACTIVE", "WAITING_FOR_CONFIRMATION", "EVIDENCE_REQUIRED", "CORRECTION", "REVIEW_ONLY", "PAUSED", "COMPLETED"]
    },
    "assertion_status": {
      "enum": ["confirmed", "not_checked", "insufficient_evidence", "not_applicable"]
    },
    "created_from_v0_2": {
      "enum": ["user_confirmation", "editor_screenshot", "structure_panel_screenshot", "frontend_screenshot", "diagnostic", "export_json", "manual_import", "initial"]
    },
    "assertion": {
      "type": "object",
      "required": ["assertion_id", "subject_ref", "claim", "status", "evidence_refs"],
      "properties": {
        "assertion_id": { "type": "string", "minLength": 1 },
        "subject_ref": { "type": "string", "minLength": 1 },
        "claim": { "type": "string", "minLength": 1 },
        "status": { "$ref": "#/$defs/assertion_status" },
        "evidence_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "confirmed" } }, "required": ["status"] },
          "then": { "properties": { "evidence_refs": { "minItems": 1 } } }
        }
      ],
      "additionalProperties": false
    },
    "retry_policy": {
      "type": "object",
      "required": ["max_retry_per_action", "retry_1", "retry_2", "retry_3"],
      "properties": {
        "max_retry_per_action": { "const": 3, "description": "MAX_RETRY_COUNT = 3" },
        "retry_1": { "const": "clarify_instruction" },
        "retry_2": { "const": "request_targeted_screenshot" },
        "retry_3": { "const": "enter_CORRECTION" }
      },
      "additionalProperties": false
    },
    "legacy_checkpoint_v0_1": {
      "type": "object",
      "required": ["schema", "checkpoint_id", "current_section", "completed_elements", "applied_classes", "verified_settings", "unconfirmed_settings", "last_completed_action", "next_pending_action"],
      "properties": {
        "schema": { "const": "ev4-builder-checkpoint@0.1.0" },
        "checkpoint_id": { "type": "string", "minLength": 1 },
        "created_from": { "enum": ["user_confirmation", "editor_screenshot", "frontend_screenshot", "diagnostic_evidence", "manual_status_import", "initial"] },
        "current_section": { "type": ["string", "null"] },
        "current_handoff_or_context_package": { "type": ["string", "null"] },
        "selected_candidate_id": { "type": ["string", "null"] },
        "completed_elements": { "type": "array", "items": { "type": "string" } },
        "applied_classes": { "type": "array", "items": { "type": "string" } },
        "verified_settings": { "type": "array", "items": { "type": "string" } },
        "unconfirmed_settings": { "type": "array", "items": { "type": "string" } },
        "active_warnings": { "type": "array", "items": { "type": "string" } },
        "unresolved_evidence": { "type": "array", "items": { "type": "string" } },
        "last_completed_action": { "type": ["string", "null"] },
        "next_pending_action": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "checkpoint_v0_2": {
      "type": "object",
      "required": [
        "schema",
        "checkpoint_id",
        "checkpoint_sequence",
        "parent_checkpoint_id",
        "package_id",
        "package_sha256",
        "selected_candidate_id",
        "workflow_mode",
        "runtime_state",
        "batch_id",
        "confirmed_action_ids",
        "unconfirmed_action_ids",
        "assertions",
        "evidence_ledger",
        "retry_policy",
        "created_at",
        "created_from"
      ],
      "properties": {
        "schema": { "const": "ev4-builder-checkpoint@0.2.0" },
        "checkpoint_id": { "type": "string", "minLength": 1 },
        "checkpoint_sequence": { "type": "integer", "minimum": 1 },
        "parent_checkpoint_id": { "type": ["string", "null"] },
        "package_id": { "type": "string", "minLength": 1 },
        "package_sha256": { "type": "string", "pattern": "^[a-fA-F0-9]{64}$" },
        "selected_candidate_id": { "type": "string", "minLength": 1 },
        "workflow_mode": { "$ref": "#/$defs/workflow_mode" },
        "runtime_state": { "$ref": "#/$defs/runtime_state" },
        "batch_id": { "type": "string", "minLength": 1 },
        "confirmed_action_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "unconfirmed_action_ids": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true },
        "assertions": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/assertion" } },
        "evidence_ledger": { "type": "array", "items": { "$ref": "./evidence-record.schema.json" } },
        "retry_policy": { "$ref": "#/$defs/retry_policy" },
        "created_at": { "type": "string", "format": "date-time" },
        "created_from": { "$ref": "#/$defs/created_from_v0_2" }
      },
      "additionalProperties": false
    }
  },
  "oneOf": [
    { "$ref": "#/$defs/legacy_checkpoint_v0_1" },
    { "$ref": "#/$defs/checkpoint_v0_2" }
  ]
}
