{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/ev4/elementor-asset-generation-check.schema.json",
  "title": "EV4 Elementor Asset Generation Check",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "asset_type",
    "target_use",
    "generated_by_builder",
    "knowledge_lookup_performed",
    "local_kb_checked",
    "local_kb_sources",
    "official_docs_checked",
    "official_docs_required",
    "official_docs_refs",
    "compatibility_profile",
    "contains_forbidden_features",
    "forbidden_features_detected",
    "required_features_present",
    "safe_to_generate",
    "reason",
    "required_next_action"
  ],
  "properties": {
    "schema": { "const": "ev4-elementor-asset-generation-check@0.1.0" },
    "asset_type": { "enum": ["svg", "image", "html", "lottie", "other"] },
    "target_use": { "type": "string", "minLength": 1 },
    "generated_by_builder": { "type": "boolean" },
    "knowledge_lookup_performed": { "type": "boolean" },
    "local_kb_checked": { "type": "boolean" },
    "local_kb_sources": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "official_docs_checked": { "type": "boolean" },
    "official_docs_required": { "type": "boolean" },
    "official_docs_refs": { "type": "array", "items": { "type": "string" } },
    "compatibility_profile": { "type": ["string", "null"] },
    "contains_forbidden_features": { "type": "boolean" },
    "forbidden_features_detected": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "required_features_present": { "type": "boolean" },
    "safe_to_generate": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "required_next_action": { "enum": ["generate_asset", "do_not_generate", "repair_packet_required", "request_evidence"] },
    "local_kb_conflicts_with_official_docs": { "type": "boolean", "default": false },
    "already_generated": { "type": "boolean", "default": false },
    "repair_packet_required": { "type": "boolean", "default": false }
  }
}
