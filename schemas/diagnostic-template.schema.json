{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "EV4 Diagnostic Template Registry",
  "type": "object",
  "required": ["schema", "version", "templates"],
  "properties": {
    "schema": { "const": "ev4-diagnostic-template-registry@1.0.0" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["template_id", "template_version", "description", "mode", "allowed_contexts", "token_schema", "code_template_encoding", "code_template_base64", "output_limitation"],
        "properties": {
          "template_id": { "type": "string", "pattern": "^[a-z0-9_]+_v[0-9]+$" },
          "template_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "description": { "type": "string", "minLength": 1 },
          "mode": { "const": "read_only" },
          "allowed_contexts": { "type": "array", "minItems": 1, "items": { "enum": ["CORRECTION", "EVIDENCE_REQUIRED", "insufficient_evidence", "repair", "claim_level_verification"] } },
          "token_schema": {
            "type": "object",
            "required": ["tokens", "selector_pattern", "label_max_length", "max_targets"],
            "properties": {
              "tokens": { "type": "array", "items": { "enum": ["label", "selector"] }, "contains": { "const": "selector" } },
              "selector_pattern": { "const": "^[A-Za-z0-9_.#\\\\- >]+$" },
              "label_max_length": { "type": "integer", "minimum": 1, "maximum": 120 },
              "max_targets": { "type": "integer", "minimum": 1, "maximum": 20 }
            },
            "additionalProperties": false
          },
          "code_template_encoding": { "const": "base64" },
          "code_template_base64": { "type": "string", "minLength": 1 },
          "output_limitation": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
