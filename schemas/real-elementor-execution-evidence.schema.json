{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Builder-Assistant-Repo/schemas/real-elementor-execution-evidence.schema.json",
  "title": "EV4 Real Elementor Execution Evidence",
  "type": "object",
  "required": [
    "schema",
    "evidence_id",
    "selected_candidate_id",
    "execution_status",
    "source_package_ref",
    "builder_session_ref",
    "elementor_environment",
    "evidence_items",
    "verification_summary",
    "production_ready_claim",
    "required_next_action"
  ],
  "properties": {
    "schema": { "const": "ev4-real-elementor-execution-evidence@1.0.0" },
    "evidence_id": { "type": "string", "minLength": 1 },
    "selected_candidate_id": { "const": "ARCH-FAM-C" },
    "execution_status": { "enum": ["not_started", "in_progress", "blocked", "completed"] },
    "source_package_ref": { "type": "string", "minLength": 1 },
    "builder_session_ref": { "type": "string", "minLength": 1 },
    "elementor_environment": {
      "type": "object",
      "required": ["site_ref", "elementor_version_status", "browser", "viewport_set"],
      "properties": {
        "site_ref": { "type": "string", "minLength": 1 },
        "elementor_version_status": { "enum": ["confirmed", "unknown", "not_recorded"] },
        "elementor_version": { "type": "string" },
        "browser": { "type": "string", "minLength": 1 },
        "viewport_set": {
          "type": "array",
          "minItems": 1,
          "items": { "enum": ["desktop", "tablet", "mobile"] }
        }
      },
      "additionalProperties": false
    },
    "evidence_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["evidence_ref", "evidence_type", "viewport", "status", "description"],
        "properties": {
          "evidence_ref": { "type": "string", "minLength": 1 },
          "evidence_type": { "enum": ["screenshot", "screen_recording", "ui_observation", "export_artifact", "accessibility_note", "browser_note"] },
          "viewport": { "enum": ["desktop", "tablet", "mobile", "all", "not_applicable"] },
          "status": { "enum": ["confirmed", "missing", "blocked", "not_applicable"] },
          "description": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      }
    },
    "verification_summary": {
      "type": "object",
      "required": ["layout_verified", "visual_parity_verified", "responsive_verified", "content_visibility_verified", "connector_behavior_verified", "accessibility_checked", "export_checked"],
      "properties": {
        "layout_verified": { "$ref": "#/$defs/proof" },
        "visual_parity_verified": { "$ref": "#/$defs/proof" },
        "responsive_verified": { "$ref": "#/$defs/proof" },
        "content_visibility_verified": { "$ref": "#/$defs/proof" },
        "connector_behavior_verified": { "$ref": "#/$defs/proof" },
        "accessibility_checked": { "$ref": "#/$defs/proof" },
        "export_checked": { "$ref": "#/$defs/proof" }
      },
      "additionalProperties": false
    },
    "repair_packet_required": { "type": "boolean" },
    "repair_packet_ref": { "type": "string" },
    "production_ready_claim": { "type": "boolean" },
    "required_next_action": { "enum": ["collect_real_ui_evidence", "continue_execution", "create_repair_packet", "run_completion_gate", "claim_production_ready"] },
    "notes": { "type": "string" }
  },
  "$defs": {
    "proof": {
      "type": "object",
      "required": ["status", "evidence_refs"],
      "properties": {
        "status": { "enum": ["confirmed", "missing", "blocked", "not_applicable"] },
        "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
