{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Builder-Assistant-Repo/schemas/unit-strategy-check.schema.json",
  "title": "EV4 Unit Strategy Check",
  "type": "object",
  "required": ["schema", "control", "proposed_value", "proposed_unit", "value_source", "responsive_scope", "affects_layout", "affects_position", "risk_level", "reversible", "safe_to_emit", "reason", "required_next_action"],
  "properties": {
    "schema": { "const": "ev4-unit-strategy-check@0.1.0" },
    "control": { "type": "string", "minLength": 1 },
    "proposed_value": { "type": "number" },
    "proposed_unit": { "type": "string", "minLength": 1 },
    "value_source": { "enum": ["package_approved", "user_confirmed", "visible_ui", "measured_layout", "asset_intrinsic", "temporary_calibration", "official_docs", "unknown"] },
    "responsive_scope": { "enum": ["desktop_only", "breakpoint_specific", "global", "unknown"] },
    "affects_layout": { "type": "boolean" },
    "affects_position": { "type": "boolean" },
    "risk_level": { "enum": ["low", "medium", "high", "blocked"] },
    "reversible": { "type": "boolean" },
    "safe_to_emit": { "type": "boolean" },
    "reason": { "type": "string", "minLength": 1 },
    "required_next_action": { "enum": ["emit_value", "ask_unit_strategy", "ask_targeted_evidence", "create_repair_packet", "do_not_emit"] },
    "asset_intrinsic_dimensions": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "value_source": { "const": "asset_intrinsic" },
          "safe_to_emit": { "const": true }
        },
        "anyOf": [
          { "properties": { "affects_layout": { "const": true } }, "required": ["affects_layout"] },
          { "properties": { "affects_position": { "const": true } }, "required": ["affects_position"] }
        ],
        "required": ["value_source", "safe_to_emit"]
      },
      "then": false
    },
    {
      "if": { "properties": { "safe_to_emit": { "const": true } }, "required": ["safe_to_emit"] },
      "then": {
        "properties": {
          "value_source": { "not": { "const": "unknown" } },
          "responsive_scope": { "not": { "const": "unknown" } },
          "reversible": { "const": true },
          "required_next_action": { "const": "emit_value" }
        }
      }
    }
  ],
  "additionalProperties": false
}
