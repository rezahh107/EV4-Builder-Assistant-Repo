{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Builder-Assistant-Repo/schemas/completion-gate.schema.json",
  "title": "EV4 Completion Gate",
  "type": "object",
  "required": [
    "schema",
    "gate_id",
    "selected_candidate_id",
    "source_package_ref",
    "layout_check_ref",
    "production_ready_allowed",
    "production_ready_claim",
    "proofs",
    "required_next_action",
    "reason"
  ],
  "properties": {
    "schema": { "const": "ev4-completion-gate@0.1.0" },
    "gate_id": { "type": "string", "minLength": 1 },
    "selected_candidate_id": { "type": "string", "minLength": 1 },
    "source_package_ref": { "type": "string", "minLength": 1 },
    "layout_check_ref": { "type": "string", "minLength": 1 },
    "production_ready_allowed": { "type": "boolean" },
    "production_ready_claim": { "type": "boolean" },
    "proofs": {
      "type": "object",
      "required": [
        "layout_verified",
        "frontend_verified",
        "responsive_verified",
        "accessibility_verified",
        "browser_verified",
        "export_verified",
        "final_qa_verified"
      ],
      "properties": {
        "layout_verified": { "$ref": "#/$defs/proof" },
        "frontend_verified": { "$ref": "#/$defs/proof" },
        "responsive_verified": { "$ref": "#/$defs/proof" },
        "accessibility_verified": { "$ref": "#/$defs/proof" },
        "browser_verified": { "$ref": "#/$defs/proof" },
        "export_verified": { "$ref": "#/$defs/proof" },
        "final_qa_verified": { "$ref": "#/$defs/proof" }
      },
      "additionalProperties": false
    },
    "required_next_action": { "enum": ["claim_production_ready", "keep_production_ready_false", "ask_missing_evidence", "create_repair_packet", "review_only"] },
    "reason": { "type": "string", "minLength": 1 }
  },
  "$defs": {
    "proof": {
      "type": "object",
      "required": ["status", "evidence_refs"],
      "properties": {
        "status": { "enum": ["confirmed", "missing", "unverified", "not_applicable"] },
        "evidence_refs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": { "properties": { "production_ready_allowed": { "const": true } }, "required": ["production_ready_allowed"] },
      "then": {
        "properties": {
          "production_ready_claim": { "const": true },
          "required_next_action": { "const": "claim_production_ready" },
          "proofs": {
            "properties": {
              "layout_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } },
              "frontend_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } },
              "responsive_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } },
              "accessibility_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } },
              "browser_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } },
              "export_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } },
              "final_qa_verified": { "properties": { "status": { "const": "confirmed" }, "evidence_refs": { "minItems": 1 } } }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "production_ready_claim": { "const": true } }, "required": ["production_ready_claim"] },
      "then": { "properties": { "production_ready_allowed": { "const": true }, "required_next_action": { "const": "claim_production_ready" } } }
    },
    {
      "if": { "properties": { "production_ready_allowed": { "const": false } }, "required": ["production_ready_allowed"] },
      "then": { "properties": { "production_ready_claim": { "const": false }, "required_next_action": { "not": { "const": "claim_production_ready" } } } }
    }
  ],
  "additionalProperties": false
}
