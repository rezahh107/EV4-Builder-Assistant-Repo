{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rezahh107/EV4-Builder-Assistant-Repo/schemas/reference-paradigm-gate.schema.json",
  "title": "EV4 Reference Paradigm Gate",
  "description": "Structured Builder-side gate for Constructability Engineer reference paradigm locks.",
  "type": "object",
  "required": [
    "reference_paradigm_lock",
    "paradigm_to_structure_map"
  ],
  "properties": {
    "reference_paradigm_lock": {
      "type": "object",
      "required": [
        "schema",
        "source_reference_id",
        "extracted_by",
        "paradigm_locked",
        "layout_paradigm",
        "primary_anchor",
        "distribution_model",
        "repeated_unit_form",
        "spatial_symmetry",
        "completion_signature"
      ],
      "properties": {
        "schema": {
          "const": "ev4-reference-paradigm-lock@1.0.0"
        },
        "source_reference_id": {
          "type": "string",
          "minLength": 1
        },
        "extracted_by": {
          "const": "constructability_engineer"
        },
        "paradigm_locked": {
          "const": true
        },
        "layout_paradigm": {
          "type": "string",
          "minLength": 1
        },
        "primary_anchor": {
          "type": "string",
          "minLength": 1
        },
        "distribution_model": {
          "type": "string",
          "minLength": 1
        },
        "repeated_unit_form": {
          "type": "string",
          "minLength": 1
        },
        "connector_model": {
          "type": "string",
          "minLength": 1
        },
        "spatial_symmetry": {
          "type": "string",
          "minLength": 1
        },
        "completion_signature": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "additionalProperties": false
    },
    "paradigm_to_structure_map": {
      "type": "object",
      "required": [
        "primary_anchor",
        "regions",
        "repeated_units",
        "first_batch_requirements"
      ],
      "properties": {
        "primary_anchor": {
          "type": "string",
          "minLength": 1
        },
        "regions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "repeated_units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "connector_layer": {
          "type": "string",
          "minLength": 1
        },
        "first_batch_requirements": {
          "type": "object",
          "properties": {
            "must_establish_primary_anchor": {
              "type": "boolean"
            },
            "must_create_or_stage_left_right_regions": {
              "type": "boolean"
            },
            "must_use_repeated_unit_form": {
              "type": "string",
              "minLength": 1
            },
            "forbidden_composition_starts": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "connector_strategy": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
